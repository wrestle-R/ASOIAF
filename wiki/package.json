{
  "name": "map-of-ice-and-fire",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"node --watch server/index.js\" \"vite\"",
    "start": "node server/index.js",
    "prepare:db": "node scripts/prepare-database.mjs",
    "build:web-db": "node scripts/build-web-database.mjs",
    "sync:blob": "node scripts/sync-blob-assets.mjs",
    "pretest": "npm run prepare:db",
    "prebuild": "npm run prepare:db",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:catalog": "node scripts/verify-home-catalog.mjs",
    "verify:journeys": "node scripts/verify-character-journeys.mjs",
    "verify:map": "node scripts/verify-map-visuals.mjs",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@vercel/blob": "^2.6.1",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "lucide-react": "^1.24.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.13",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
